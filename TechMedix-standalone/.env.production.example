# TechMedix Production Environment Variables
# Copy this file, fill in real values, and add via Vercel dashboard or CLI
# NEVER commit real secrets to version control

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Sets which LLM backend to use. Switch between backends without changing code.
#   "ollama" (default) → local, no API key needed
#   "openai"           → any OpenAI-compatible API
#   "anthropic"        → raw HTTP to Anthropic (no SDK dependency)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=        # Supabase project URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=   # Supabase anon key (safe for browser)
SUPABASE_SERVICE_ROLE_KEY=       # Supabase service role key (server only, never expose)

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=               # Stripe secret key (sk_live_...)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY= # Stripe publishable key (pk_live_...)
STRIPE_WEBHOOK_SECRET=           # Stripe webhook signing secret (whsec_...)

# ── Resend ───────────────────────────────────────────────────────────────────
RESEND_API_KEY=                  # Resend email API key — get from resend.com

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=             # https://dashboard.blackcatrobotics.com

# ── BlackCat OS ──────────────────────────────────────────────────────────────
BLACKCAT_API_SECRET=             # Generate with: openssl rand -hex 32
CRON_SECRET=                     # Vercel cron auth secret (auto-set by Vercel)

# ── HuggingFace (Layer 2 diagnostics) ────────────────────────────────────────
HUGGINGFACE_API_TOKEN=           # HuggingFace API token for VLA inference
VLA_INFERENCE_SERVER_URL=        # Self-hosted VLA inference endpoint URL
VLA_ESCALATION_THRESHOLD=0.65   # Confidence threshold for Claude escalation

# ── Atlas API ────────────────────────────────────────────────────────────────
ATLAS_API_KEY=                   # BlackCat OS Atlas API key
ATLAS_BASE_URL=https://api.humanoidatlas.com  # Atlas base URL
